{
	"schemaVersion": 1,
	"id": "reachcrafting",
	"version": "${version}",
	"name": "Effortless Crafting",
	"description": "A client-side Fabric mod for Minecraft 26.1.x that crafts from your inventory and nearby containers through vanilla interactions.",
	"license": "LGPL-3.0-or-later",
	"icon": "assets/reachcrafting/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"com.reachcrafting.ReachCraftingMod"
		],
		"client": [
			"com.reachcrafting.client.ReachCraftingModClient"
		],
		"modmenu": [
			"com.reachcrafting.client.compat.ReachCraftingModMenuIntegration"
		]
	},
	"mixins": [
		{
			"config": "reachcrafting.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "26.1.x",
		"java": ">=25",
		"fabric-api": "*"
	},
	"suggests": {
		"modmenu": "*",
		"cloth-config": "*"
	}
}
